{
  "name": "@e-is/ngx-material-table",
  "description": "Angular 19 table based on @angular/cdk table structure, to allow row insertion, edition, validation and deletion.",
  "version": "19.0.0",
  "license": "MIT",
  "author": "Ignacio Rossi <irossimoline>",
  "keywords": [
    "angular",
    "angular 19",
    "table",
    "inline validation",
    "material design",
    "angular material table",
    "ngx material table",
    "ngx table"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/e-is/ngx-material-table.git"
  },
  "homepage": "https://github.com/e-is/ngx-material-table",
  "bugs": {
    "url": "https://github.com/e-is/ngx-material-table/issues"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development --port 4201",
    "build": "ng build --configuration production",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "packagr": "ng-packagr -p ng-package.json",
    "publish": "npm run packagr && cd dist && npm publish",
    "publish-dev": "npm run packagr && cd dist && npm publish --userconfig=.local/.npmrc",
    "prepare": "npx husky install"
  },
  "lint-staged": {
    "src/**/*.{ts,html}": [
      "prettier --write",
      "eslint --fix"
    ],
    "src/**/*.{css,json,md,scss}": "prettier --write"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "bundles/ngx-material-table.umd.js",
  "module": "index.js",
  "typings": "index.d.ts",
  "private": false,
  "dependencies": {
    "clone": "^2.1.2"
  },
  "devDependencies": {
    "@angular-devkit/architect": "~0.1902.23",
    "@angular-devkit/build-angular": "~19.2.23",
    "@angular-devkit/core": "~19.2.23",
    "@angular-devkit/schematics": "~19.2.23",
    "@angular-eslint/builder": "^18.4.3",
    "@angular-eslint/eslint-plugin": "^18.4.3",
    "@angular-eslint/eslint-plugin-template": "^18.4.3",
    "@angular-eslint/template-parser": "^18.4.3",
    "@angular/animations": "~19.2.20",
    "@angular/cdk": "~19.2.19",
    "@angular/cli": "~19.2.23",
    "@angular/common": "~19.2.20",
    "@angular/compiler": "~19.2.20",
    "@angular/compiler-cli": "~19.2.20",
    "@angular/core": "~19.2.20",
    "@angular/forms": "~19.2.20",
    "@angular/language-service": "~19.2.20",
    "@angular/material": "~19.2.19",
    "@angular/platform-browser": "~19.2.20",
    "@angular/platform-browser-dynamic": "~19.2.20",
    "@angular/router": "~19.2.20",
    "@types/jasmine": "~5.1.4",
    "@types/jasminewd2": "~2.0.13",
    "@types/node": "~18.19.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@typescript-eslint/utils": "^7.18.0",
    "eslint": "~8.57.1",
    "eslint-config-prettier": "~9.1.0",
    "eslint-plugin-import": "latest",
    "eslint-plugin-jsdoc": "latest",
    "eslint-plugin-prefer-arrow": "latest",
    "eslint-plugin-prettier": "latest",
    "husky": "^8.0.3",
    "jasmine-core": "~5.1.1",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "material-design-icons": "^3.0.1",
    "ng-packagr": "~19.2.2",
    "ng-table-virtual-scroll": "^1.6.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "rollup": "^4.8.0",
    "rxjs": "~7.8.2",
    "ts-node": "~10.9.2",
    "tslib": "~2.3.0",
    "typescript": "~5.5.4"
  },
  "peerDependencies": {
    "webpack": "5.94.0",
    "zone.js": "~0.15.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "~4.41.0"
  },
  "engines": {
    "node": ">= 20.17.0",
    "npm": ">= 10.7.0",
    "yarn": ">= 1.22.0"
  }
}
